var int currentDir = 0
var int posCount = 0
var int flipBar = 0
var float flipPrice = 0.0
var int flipDir = 0
var int lastEvtTime = 0
var int lastSignalBar = na
var float lastSignalScore = na
var int winsA = 0
var int lossesA = 0
var int winsB = 0
var int lossesB = 0
var float pnlSumA = 0.0
var float pnlSumB = 0.0
var int totalFlips = 0
var int[] recentB = array.new_int(0)
var int totalHoldBarsB = 0

trendLongOk = close > emaBasis and emaBasis >= emaBasis[1]
trendShortOk = close < emaBasis and emaBasis <= emaBasis[1]
rsiLongOk = rsiValue >= 50
rsiShortOk = rsiValue <= 50
volatilityOk = atrPct >= minAtrPct
htfLongOk = htfClose >= htfEma
htfShortOk = htfClose <= htfEma

int barsSinceSignal = not na(lastSignalBar) ? bar_index - lastSignalBar : na
int remainingBars = not na(barsSinceSignal) ? math.max(signalLifeBars - barsSinceSignal, 0) : na
float agedScore = not na(lastSignalScore) and not na(barsSinceSignal) ? clampFloat(lastSignalScore - barsSinceSignal * 25.0 / signalLifeBars, 0, 100) : na
isSignalExpired = currentDir != 0 and not na(remainingBars) and remainingBars <= 0
effectiveDir = isSignalExpired ? 0 : currentDir
expiredNow = isSignalExpired and (bar_index == 0 or not isSignalExpired[1])

bool flipSignalNow = false
bool addSignalNow = false
bool filteredSignalNow = false
int alertDir = 0
var string lastFilterText = "等待事件"

if totalFlips > 0 and currentDir != 0 and bar_index - flipBar == holdBars
    pnlPctA = (flipDir == 1 ? close - flipPrice : flipPrice - close) / flipPrice * 100
    pnlSumA += pnlPctA
    if pnlPctA > 0
        winsA += 1
    else
        lossesA += 1

if array.size(evt_time) > 0
    for i = 0 to array.size(evt_time) - 1
        if time_close > array.get(evt_time, i) and time_close[1] <= array.get(evt_time, i)
            d = array.get(evt_dir, i)
            s = array.get(evt_str, i)
            tip = array.get(evt_tips, i)
            trendOk = d == 1 ? trendLongOk : trendShortOk
            rsiOk = d == 1 ? rsiLongOk : rsiShortOk
            htfOk = d == 1 ? htfLongOk : htfShortOk
            passFilters = (not useTrendFilter or trendOk) and (not useRsiFilter or rsiOk) and (not useVolFilter or volatilityOk) and (not useHtfConfirm or htfOk)
            filterText = formatFilterSummary(useTrendFilter, trendOk, useRsiFilter, rsiOk, useVolFilter, volatilityOk, useHtfConfirm, htfOk)
            baseScore = 35.0 + s * 15.0 + profileBias(assetProfile)
            filterScore = (useTrendFilter ? (trendOk ? TREND_FILTER_BONUS : TREND_FILTER_PENALTY) : 0.0) + (useRsiFilter ? (rsiOk ? RSI_FILTER_BONUS : RSI_FILTER_PENALTY) : 0.0) + (useVolFilter ? (volatilityOk ? VOL_FILTER_BONUS : VOL_FILTER_PENALTY) : 0.0) + (useHtfConfirm ? (htfOk ? HTF_FILTER_BONUS : HTF_FILTER_PENALTY) : 0.0)
            score = clampFloat(baseScore + filterScore, 0, 100)
            scoreText = "品質分數: " + str.tostring(score, "#.0") + " (" + qualityLabel(score) + ")"
            filterStatusText = "濾網: " + filterText
            positionText = d == 1 ? "建議買入: " + str.tostring(baseRiskPct * positionFactor(score), "#.0") + "% (依強度)" : "建議賣出: " + str.tostring(sellBatchPct, "#.0") + "% / 次"
            richTip = tip + "\n" + scoreText + "\n" + filterStatusText + "\n" + positionText

            lastFilterText := filterText
            if passFilters
                alertDir := d
                lastEvtTime := array.get(evt_time, i)
                lastSignalBar := bar_index
                lastSignalScore := score
                isFlip = d != currentDir

                if isFlip
                    if totalFlips > 0
                        pnlPctB = (flipDir == 1 ? close - flipPrice : flipPrice - close) / flipPrice * 100
                        pnlSumB += pnlPctB
                        totalHoldBarsB += bar_index - flipBar
                        if pnlPctB > 0
                            winsB += 1
                            array.push(recentB, 1)
                        else
                            lossesB += 1
                            array.push(recentB, 0)
                        if array.size(recentB) > 20
                            array.shift(recentB)
                    currentDir := d
                    posCount := 1
                    flipBar := bar_index
                    flipPrice := close
                    flipDir := d
                    totalFlips += 1
                    flipSignalNow := true
                    labelSize = s == 3 ? size.huge : s == 2 ? size.large : size.normal
                    if d == 1
                        label.new(bar_index, low - gap, "▲",
                             color=color.new(color.black, 100),
                             textcolor=#00E676,
                             style=label.style_label_up,
                             size=labelSize,
                             tooltip=richTip)
                    else
                        label.new(bar_index, high + gap, "▼",
                             color=color.new(color.black, 100),
                             textcolor=#FF1744,
                             style=label.style_label_down,
                             size=labelSize,
                             tooltip=richTip)
                else
                    posCount := math.min(posCount + 1, maxPyramid)
                    addSignalNow := true
                    if showDots
                        dotCol = d == 1 ? color.new(#00E676, 50) : color.new(#FF1744, 50)
                        dotY = d == 1 ? low - gap * 2 : high + gap * 2
                        label.new(bar_index, dotY, d == 1 ? "▲" : "▼",
                             color=color.new(color.black, 100),
                             textcolor=dotCol,
                             style=d == 1 ? label.style_label_up : label.style_label_down,
                             size=size.large,
                             tooltip=richTip)
            else
                filteredSignalNow := true
                if showFilteredMarks
                    label.new(bar_index, d == 1 ? low - gap : high + gap, "×",
                         color=color.new(color.black, 100),
                         textcolor=color.new(color.gray, 0),
                         style=d == 1 ? label.style_label_up : label.style_label_down,
                         size=size.small,
                         tooltip=tip + "\n原始事件遭濾網擋下\n" + filterText)

color bgCol = na
if showBg and effectiveDir == 1
    bgCol := color.new(#00E676, 95)
if showBg and effectiveDir == -1
    bgCol := color.new(#FF1744, 95)
bgcolor(bgCol)

float avgPnlA = winsA + lossesA > 0 ? pnlSumA / (winsA + lossesA) : na
judgedBCount = winsB + lossesB
float avgPnlB = judgedBCount > 0 ? pnlSumB / judgedBCount : na
float avgHoldB = judgedBCount > 0 ? totalHoldBarsB * 1.0 / judgedBCount : na
float recentWinB = na
if array.size(recentB) > 0
    recentWins = 0
    for i = 0 to array.size(recentB) - 1
        recentWins += array.get(recentB, i)
    recentWinB := recentWins / array.size(recentB) * 100

activeTrendOk = effectiveDir == 1 ? trendLongOk : effectiveDir == -1 ? trendShortOk : true
activeRsiOk = effectiveDir == 1 ? rsiLongOk : effectiveDir == -1 ? rsiShortOk : true
activeHtfOk = effectiveDir == 1 ? htfLongOk : effectiveDir == -1 ? htfShortOk : true
riskPct = effectiveDir == 0 or na(agedScore) ? 0.0 : baseRiskPct * positionFactor(agedScore)
stopAtr = profileStopAtr(assetProfile)
riskText = effectiveDir == 0 ? "等待下一筆翻轉" : effectiveDir == 1 ? str.tostring(riskPct, "#.0") + "% / 停損 " + str.tostring(stopAtr, "#.1") + " ATR / 分批買入" : "每次賣 " + str.tostring(sellBatchPct, "#.0") + "% / 停損 " + str.tostring(stopAtr, "#.1") + " ATR / 逐批出場"
qualityText = not na(agedScore) ? str.tostring(agedScore, "#.0") + " / 100 (" + qualityLabel(agedScore) + ")" : "尚無"
float ageHours = lastEvtTime > 0 ? (timenow - lastEvtTime) / 3600000.0 : na
ageText = formatSignalAge(lastEvtTime, isSignalExpired, ageHours)
validityText = effectiveDir == 0 ? (isSignalExpired ? "等待新訊號" : "尚未啟用") : str.tostring(remainingBars) + " 根 K 棒內有效"
filterCompact = formatFilterSummary(useTrendFilter, activeTrendOk, useRsiFilter, activeRsiOk, useVolFilter, volatilityOk, useHtfConfirm, activeHtfOk)
positionPctText = str.tostring((posCount * 100.0) / maxPyramid, "#.0")

if showPanel
    pos = panelPos == "右上" ? position.top_right : position.bottom_right
    var table t = table.new(pos, 2, 13, bgcolor=color.new(#111111, 5), border_color=color.new(#555555, 0), border_width=1)
    if barstate.islast
        dashboardDirectionLabel = effectiveDir == 1 ? "偏多 ▲" : effectiveDir == -1 ? "偏空 ▼" : isSignalExpired ? "訊號過期" : "等訊號"
        dirCol = effectiveDir == 1 ? #00E676 : effectiveDir == -1 ? #FF1744 : color.gray
        judgedA = winsA + lossesA
        winRateA = judgedA > 0 ? winsA / judgedA * 100 : 0
        wrColA = winRateA >= 60 ? #00E676 : winRateA >= 40 ? #ffeb3b : #FF1744
        judgedB = winsB + lossesB
        winRateB = judgedB > 0 ? winsB / judgedB * 100 : 0
        wrColB = winRateB >= 60 ? #00E676 : winRateB >= 40 ? #ffeb3b : #FF1744
        qualityCol = not na(agedScore) ? agedScore >= 80 ? #00E676 : agedScore >= 65 ? #ffeb3b : #FF7043 : color.gray
        ageCol = isSignalExpired ? color.gray : not na(ageHours) and ageHours < 24 ? color.white : #ffeb3b
        suggest = winRateB > winRateA ? "建議: 用翻轉平倉作主策略" : winRateA > winRateB ? "建議: 固定 " + str.tostring(holdBars) + " 棒出場" : "建議: 兩者差不多，優先看品質分數"
        sugCol = winRateB > winRateA ? #00E676 : winRateA > winRateB ? #ffeb3b : color.gray
        table.cell(t, 0, 0, "8zz 情緒反轉框架 [Community]", text_color=color.white, text_size=size.small, bgcolor=color.new(#333333, 0))
        table.cell(t, 1, 0, assetProfile, text_color=color.white, text_size=size.small, bgcolor=color.new(#333333, 0))
        table.cell(t, 0, 1, "方向", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 1, dashboardDirectionLabel, text_color=dirCol, text_size=size.normal)
        table.cell(t, 0, 2, "倉位", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 2, str.tostring(posCount) + "/" + str.tostring(maxPyramid) + " (" + positionPctText + "%)", text_color=color.white, text_size=size.small)
        table.cell(t, 0, 3, "訊號品質", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 3, qualityText, text_color=qualityCol, text_size=size.small)
        table.cell(t, 0, 4, "訊號年齡", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 4, ageText, text_color=ageCol, text_size=size.small)
        table.cell(t, 0, 5, "有效期", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 5, validityText, text_color=isSignalExpired ? color.gray : color.white, text_size=size.small)
        table.cell(t, 0, 6, "風控", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 6, riskText, text_color=color.white, text_size=size.small)
        table.cell(t, 0, 7, "濾網", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 7, filterCompact, text_color=color.white, text_size=size.tiny)
        table.cell(t, 0, 8, "固定 " + str.tostring(holdBars) + " 棒", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 8, str.tostring(winRateA, "#.0") + "% / Avg " + (na(avgPnlA) ? "n/a" : str.tostring(avgPnlA, "#.2") + "%"), text_color=wrColA, text_size=size.small)
        table.cell(t, 0, 9, "翻轉平倉", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 9, str.tostring(winRateB, "#.0") + "% / Avg " + (na(avgPnlB) ? "n/a" : str.tostring(avgPnlB, "#.2") + "%"), text_color=wrColB, text_size=size.small)
        table.cell(t, 0, 10, "最近 20 筆 / 平均持有", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 10, (na(recentWinB) ? "n/a" : str.tostring(recentWinB, "#.0") + "%") + " / " + (na(avgHoldB) ? "n/a" : str.tostring(avgHoldB, "#.1") + " bars"), text_color=color.white, text_size=size.small)
        table.cell(t, 0, 11, suggest, text_color=sugCol, text_size=size.tiny)
        table.cell(t, 1, 11, lastFilterText, text_color=color.gray, text_size=size.tiny)
        table.cell(t, 0, 12, "情緒解讀", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 12, "被套/停損→▲偏多 | 追漲/樂觀→▼偏空", text_color=color.new(#aaaaaa, 0), text_size=size.tiny)

alertcondition(flipSignalNow and alertDir == 1, "8zz 多頭翻轉", "8zz 社群情緒反轉框架出現偏多翻轉訊號")
alertcondition(flipSignalNow and alertDir == -1, "8zz 空頭翻轉", "8zz 社群情緒反轉框架出現偏空翻轉訊號")
alertcondition(addSignalNow, "8zz 同向加碼", "8zz 社群情緒反轉框架出現同向加碼訊號")
alertcondition(filteredSignalNow, "8zz 原始事件遭濾網擋下", "有事件觸發，但被目前濾網條件擋下")
alertcondition(expiredNow, "8zz 訊號失效", "目前有效訊號已過期，等待下一次翻轉")
