indicator("8zz反指標", overlay=true, max_labels_count=500, timeframe="", timeframe_gaps=false)

// ============================================================
// 設定
// ============================================================
grp1 = "顯示"
offset_pct = input.float(2.0, "箭頭距離 %", minval=0.5, maxval=5.0, step=0.1, group=grp1)
showDots = input.bool(false, "顯示加倉圓點", group=grp1, tooltip="開啟後同方向訊號會顯示小圓點")
showPanel = input.bool(true, "顯示資訊面板", group=grp1)

grp2 = "回測"
holdBars = input.int(5, "觀察K棒數", minval=1, maxval=50, group=grp2, tooltip="翻轉後幾根K棒判定勝敗\n1小時線: 5=5小時 | 日線: 5=一週")

