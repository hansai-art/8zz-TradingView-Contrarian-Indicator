// ============================================================
// 主邏輯
// ============================================================
var int currentDir = 0
var int posCount = 0
var int flipBar = 0
var float flipPrice = 0.0
var int flipDir = 0
var int wins = 0
var int losses = 0
var int totalFlips = 0

// 觀察窗到期結算
if totalFlips > 0 and currentDir != 0 and bar_index - flipBar == holdBars
    float pnl = flipDir == 1 ? close - flipPrice : flipPrice - close
    if pnl > 0
        wins += 1
    else
        losses += 1

if array.size(evt_time) > 0
    for i = 0 to array.size(evt_time) - 1
        if time >= array.get(evt_time, i) and time[1] < array.get(evt_time, i)
            int d = array.get(evt_dir, i)
            string tip = array.get(evt_tips, i)
            float gap = (high - low) * offset_pct
            bool isFlip = d != currentDir

            if isFlip
                currentDir := d
                posCount := 1
                flipBar := bar_index
                flipPrice := close
                flipDir := d
                totalFlips += 1

                if d == 1
                    label.new(bar_index, low - gap, "▲",
                         color=color.new(color.black, 100),
                         textcolor=#00E676,
                         style=label.style_label_up,
                         size=size.huge,
                         tooltip=tip)
                else
                    label.new(bar_index, high + gap, "▼",
                         color=color.new(color.black, 100),
                         textcolor=#FF1744,
                         style=label.style_label_down,
                         size=size.huge,
                         tooltip=tip)
            else
                posCount := math.min(posCount + 1, 5)
                if showDots
                    color dotCol = d == 1 ? #00E676 : #FF1744
                    float dotY = d == 1 ? low - gap * 0.3 : high + gap * 0.3
                    label.new(bar_index, dotY, "",
                         color=dotCol,
                         style=label.style_circle,
                         size=size.tiny,
                         tooltip=tip)

// ============================================================
// 資訊面板
// ============================================================
if showPanel
    var table t = table.new(position.top_right, 2, 5, bgcolor=color.new(#1e1e1e, 10), border_color=color.new(#555555, 0), border_width=1)
    if barstate.islast
        string dirStr = currentDir == 1 ? "偏多 ▲" : currentDir == -1 ? "偏空 ▼" : "等訊號"
        color dirCol = currentDir == 1 ? #00E676 : currentDir == -1 ? #FF1744 : color.gray
        int judged = wins + losses
        float winRate = judged > 0 ? wins / judged * 100 : 0
        color wrCol = winRate >= 60 ? #00E676 : winRate >= 40 ? #ffeb3b : #FF1744

        table.cell(t, 0, 0, "8zz 反指標", text_color=color.white, text_size=size.small, bgcolor=color.new(#333333, 0))
        table.cell(t, 1, 0, dirStr, text_color=dirCol, text_size=size.normal)
        table.cell(t, 0, 1, "倉位", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 1, str.tostring(posCount) + "/5 (" + str.tostring(posCount * 20) + "%)", text_color=color.white, text_size=size.small)
        table.cell(t, 0, 2, "勝率", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 2, str.tostring(winRate, "#.0") + "% (" + str.tostring(wins) + "W " + str.tostring(losses) + "L)", text_color=wrCol, text_size=size.small)
        table.cell(t, 0, 3, "觀察窗", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 3, str.tostring(holdBars) + " bars", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 0, 4, "翻轉次數", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 4, str.tostring(totalFlips), text_color=color.gray, text_size=size.tiny)
