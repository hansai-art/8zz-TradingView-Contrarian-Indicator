// 8zz Sentiment Reversal Framework [Community]
// 事件: 65筆 | 期間: 2025/12 ~ 2026/04
// 情緒解讀框架：負面情緒（被套、停損、恐慌）→ 偏多 ▲（散戶恐慌→主力拉升）
//               正面情緒（漲停追買、過度樂觀）→ 偏空 ▼（市場過熱→崩跌機率高）
// 免責聲明：本指標僅供娛樂參考，不構成任何投資建議。

//@version=6
indicator("8zz 情緒反轉框架 [Community]", overlay=true, max_labels_count=500)

grp1 = "顯示"
offset_atr = input.float(0.5, "箭頭距離 (ATR倍數)", minval=0.1, maxval=3.0, step=0.1, group=grp1, tooltip="越小越貼近K棒 建議0.3~0.8")
showDots   = input.bool(true, "顯示加倉箭頭", group=grp1)
showBg     = input.bool(true, "顯示背景色帶", group=grp1)
showPanel  = input.bool(true, "顯示資訊面板", group=grp1)
panelPos   = input.string("右下", "資訊面板位置", options=["右上", "右下"], group=grp1)

grp2 = "訊號治理"
holdBars = input.int(14, "固定觀察K棒數", minval=1, maxval=50, group=grp2, tooltip="模式A: 翻轉後固定幾根K棒判定勝敗")
signalLifeBars = input.int(24, "訊號有效K棒", minval=1, maxval=200, group=grp2, tooltip="超過此 K 棒數後，訊號視為過期；箭頭仍保留在歷史上，但背景與有效方向會停用")
showFilteredMarks = input.bool(false, "顯示被濾掉的原始訊號", group=grp2)

grp3 = "濾網"
useTrendFilter = input.bool(false, "EMA 趨勢濾網", group=grp3)
emaLen = input.int(55, "EMA 長度", minval=5, maxval=300, group=grp3)
useRsiFilter = input.bool(false, "RSI 動能濾網", group=grp3)
rsiLen = input.int(14, "RSI 長度", minval=2, maxval=100, group=grp3)
useVolFilter = input.bool(false, "ATR 波動濾網", group=grp3)
atrLen = input.int(14, "ATR 長度", minval=2, maxval=100, group=grp3)
minAtrPct = input.float(1.0, "最低 ATR 波動率 (%)", minval=0.1, maxval=20.0, step=0.1, group=grp3)
useHtfConfirm = input.bool(false, "高週期結構確認", group=grp3)
htfTf = input.timeframe("240", "確認週期", group=grp3)

grp4 = "執行"
assetProfile = input.string("台股個股", "標的類型", options=["ETF", "台股個股", "美股個股", "商品"], group=grp4)
baseRiskPct = input.float(20.0, "基礎建議倉位 (%)", minval=5.0, maxval=100.0, step=5.0, group=grp4)
maxPyramid = input.int(5, "最大加碼次數", minval=1, maxval=5, group=grp4)
sellBatchPct = input.float(20.0, "每次賣出比例 (%)", minval=5.0, maxval=100.0, step=5.0, group=grp4, tooltip="每個賣出訊號建議賣出的倉位比例，預設每次賣 20%")

float gap = ta.atr(14) * offset_atr
emaBasis = ta.ema(close, emaLen)
rsiValue = ta.rsi(close, rsiLen)
atrPct = ta.atr(atrLen) / close * 100.0
htfClose = request.security(syminfo.tickerid, htfTf, close)
htfEma = request.security(syminfo.tickerid, htfTf, ta.ema(close, emaLen))

TREND_FILTER_BONUS = 8.0
TREND_FILTER_PENALTY = -18.0
RSI_FILTER_BONUS = 6.0
RSI_FILTER_PENALTY = -12.0
VOL_FILTER_BONUS = 4.0
VOL_FILTER_PENALTY = -10.0
HTF_FILTER_BONUS = 10.0
HTF_FILTER_PENALTY = -18.0

clampFloat(value, minValue, maxValue) =>
    math.max(minValue, math.min(maxValue, value))

profileBias(profile) =>
    switch profile
        "台股個股" => 8.0
        "美股個股" => 3.0
        "ETF" => -8.0
        => -4.0

profileStopAtr(profile) =>
    switch profile
        "台股個股" => 1.5
        "美股個股" => 1.7
        "ETF" => 1.8
        => 2.2

qualityLabel(score) =>
    score >= 80 ? "A" : score >= 65 ? "B" : score >= 50 ? "C" : "D"

positionFactor(score) =>
    score >= 80 ? 1.0 : score >= 65 ? 0.75 : score >= 50 ? 0.5 : 0.25

filterBadge(enabled, isFilterPassed) =>
    not enabled ? "關" : isFilterPassed ? "通過" : "阻擋"

formatSignalAge(eventTime, isSignalExpired, eventAgeHours) =>
    if eventTime <= 0
        "尚無事件"
    else if isSignalExpired
        "已過期"
    else if not na(eventAgeHours) and eventAgeHours < 1
        str.tostring(eventAgeHours * 60, "#") + " 分鐘前"
    else if not na(eventAgeHours) and eventAgeHours < 48
        str.tostring(eventAgeHours, "#.0") + " 小時前"
    else
        "48 小時以上"

formatFilterSummary(useTrendFilter, trendOk, useRsiFilter, rsiOk, useVolFilter, volatilityOk, useHtfConfirm, htfOk) =>
    "EMA " + filterBadge(useTrendFilter, trendOk) + " / RSI " + filterBadge(useRsiFilter, rsiOk) + " / ATR " + filterBadge(useVolFilter, volatilityOk) + " / HTF " + filterBadge(useHtfConfirm, htfOk)

