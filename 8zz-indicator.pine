    array.push(evt_tips, "持有 | 台光電\n指標: 偏空 ▼ | 強度: ★☆☆\nFB 04/10 11:40 我不是冥燈！")

var int currentDir = 0
var int posCount = 0
var int flipBar = 0
var float flipPrice = 0.0
var int flipDir = 0
var int lastEvtTime = 0
var int winsA = 0
var int lossesA = 0
var int winsB = 0
var int lossesB = 0
var int totalFlips = 0

if totalFlips > 0 and currentDir != 0 and bar_index - flipBar == holdBars
    float pnl = flipDir == 1 ? close - flipPrice : flipPrice - close
    if pnl > 0
        winsA += 1
    else
        lossesA += 1

if array.size(evt_time) > 0
    for i = 0 to array.size(evt_time) - 1
        if time >= array.get(evt_time, i) and time[1] < array.get(evt_time, i)
            int d = array.get(evt_dir, i)
            int s = array.get(evt_str, i)
            string tip = array.get(evt_tips, i)
            bool isFlip = d != currentDir
            lastEvtTime := array.get(evt_time, i)

            if isFlip
                if totalFlips > 0
                    float pnlB = flipDir == 1 ? close - flipPrice : flipPrice - close
                    if pnlB > 0
                        winsB += 1
                    else
                        lossesB += 1
                currentDir := d
                posCount := 1
                flipBar := bar_index
                flipPrice := close
                flipDir := d
                totalFlips += 1
                string labelSize = s == 3 ? size.huge : s == 2 ? size.large : size.normal
                if d == 1
                    label.new(bar_index, low - gap, "▲",
                         color=color.new(color.black, 100),
                         textcolor=#00E676,
                         style=label.style_label_up,
                         size=labelSize,
                         tooltip=tip)
                else
                    label.new(bar_index, high + gap, "▼",
                         color=color.new(color.black, 100),
                         textcolor=#FF1744,
                         style=label.style_label_down,
                         size=labelSize,
                         tooltip=tip)
            else
                posCount := math.min(posCount + 1, 5)
                if showDots
                    color dotCol = d == 1 ? color.new(#00E676, 50) : color.new(#FF1744, 50)
                    float dotY = d == 1 ? low - gap * 2 : high + gap * 2
                    label.new(bar_index, dotY, d == 1 ? "▲" : "▼",
                         color=color.new(color.black, 100),
                         textcolor=dotCol,
                         style=d == 1 ? label.style_label_up : label.style_label_down,
                         size=size.large,
                         tooltip=tip)

color bgCol = na
if showBg and currentDir == 1
    bgCol := color.new(#00E676, 95)
if showBg and currentDir == -1
    bgCol := color.new(#FF1744, 95)
bgcolor(bgCol)

if showPanel
    string pos = panelPos == "右上" ? position.top_right : position.bottom_right
    var table t = table.new(pos, 2, 8, bgcolor=color.new(#1e1e1e, 10), border_color=color.new(#555555, 0), border_width=1)
    if barstate.islast
        string dirStr = currentDir == 1 ? "偏多 ▲" : currentDir == -1 ? "偏空 ▼" : "等訊號"
        color dirCol = currentDir == 1 ? #00E676 : currentDir == -1 ? #FF1744 : color.gray
        int judgedA = winsA + lossesA
        float winRateA = judgedA > 0 ? winsA / judgedA * 100 : 0
        color wrColA = winRateA >= 60 ? #00E676 : winRateA >= 40 ? #ffeb3b : #FF1744
        int judgedB = winsB + lossesB
        float winRateB = judgedB > 0 ? winsB / judgedB * 100 : 0
        color wrColB = winRateB >= 60 ? #00E676 : winRateB >= 40 ? #ffeb3b : #FF1744
        float ageHours = lastEvtTime > 0 ? (timenow - lastEvtTime) / 3600000.0 : 0
        string ageStr = ageHours < 1 ? str.tostring(ageHours * 60, "#") + " 分鐘前" : ageHours < 48 ? str.tostring(ageHours, "#.0") + " 小時前" : "已過期"
        color ageCol = ageHours < 24 ? color.white : ageHours < 48 ? #ffeb3b : color.gray
        table.cell(t, 0, 0, "8zz 反指標", text_color=color.white, text_size=size.small, bgcolor=color.new(#333333, 0))
        table.cell(t, 1, 0, dirStr, text_color=dirCol, text_size=size.normal)
        table.cell(t, 0, 1, "倉位", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 1, str.tostring(posCount) + "/5 (" + str.tostring(posCount * 20) + "%)", text_color=color.white, text_size=size.small)
        table.cell(t, 0, 2, "訊號年齡", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 2, ageStr, text_color=ageCol, text_size=size.small)
        table.cell(t, 0, 3, "翻轉次數", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 3, str.tostring(totalFlips), text_color=color.gray, text_size=size.tiny)
        table.cell(t, 0, 4, "勝率比較", text_color=color.white, text_size=size.tiny, bgcolor=color.new(#333333, 0))
        table.cell(t, 1, 4, "", bgcolor=color.new(#333333, 0))
        table.cell(t, 0, 5, "固定" + str.tostring(holdBars) + "棒", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 5, str.tostring(winRateA, "#.0") + "% (" + str.tostring(winsA) + "W " + str.tostring(lossesA) + "L)", text_color=wrColA, text_size=size.small)
        table.cell(t, 0, 6, "翻轉平倉", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 6, str.tostring(winRateB, "#.0") + "% (" + str.tostring(winsB) + "W " + str.tostring(lossesB) + "L)", text_color=wrColB, text_size=size.small)
        string suggest = winRateB > winRateA ? "建議: 跟著翻轉操作" : winRateA > winRateB ? "建議: 固定" + str.tostring(holdBars) + "棒平倉" : "兩者差不多"
        color sugCol = winRateB > winRateA ? #00E676 : winRateA > winRateB ? #ffeb3b : color.gray
        table.cell(t, 0, 7, suggest, text_color=sugCol, text_size=size.tiny)
        table.cell(t, 1, 7, "", text_color=sugCol, text_size=size.tiny)
